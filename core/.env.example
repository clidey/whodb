# Local backend environment for standalone login.
# Copy to core/.env or source directly before running `go run .`.

PORT=8080
WHODB_STANDALONE_LOGIN_ENABLED=true
WHODB_DISABLE_CREDENTIAL_FORM=false

# Standalone and Sealos bootstrap sessions are stored server-side.
# Use an explicit local PostgreSQL session store and an explicit 32-byte key.
WHODB_SESSION_DSN=postgres://postgres:postgres@127.0.0.1:5432/postgres?sslmode=disable
WHODB_METADATA_DSN=postgres://postgres:postgres@127.0.0.1:5432/postgres?sslmode=disable
WHODB_SESSION_ENCRYPTION_KEY=12345678901234567890123456789012
WHODB_SESSION_TTL=24h

# Leave Sealos bootstrap enabled for local URL-bootstrap testing.
WHODB_SEALOS_BOOTSTRAP_ENABLED=true
