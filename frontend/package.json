{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@apollo/client": "4.2.6",
    "@clidey/connparse": "0.7.0",
    "@clidey/ux": "0.59.0",
    "@codemirror/autocomplete": "6.20.3",
    "@codemirror/lang-json": "6.0.2",
    "@codemirror/lang-markdown": "6.5.0",
    "@codemirror/lang-sql": "6.10.0",
    "@codemirror/language": "6.12.4",
    "@codemirror/state": "6.7.1",
    "@codemirror/theme-one-dark": "6.1.3",
    "@codemirror/view": "6.43.6",
    "@dagrejs/dagre": "3.0.0",
    "@emotion/is-prop-valid": "1.4.0",
    "@heroicons/react": "2.2.0",
    "@microlink/react-json-view": "1.31.22",
    "@radix-ui/react-visually-hidden": "1.2.7",
    "@reduxjs/toolkit": "2.12.0",
    "@tailwindcss/vite": "4.3.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "classnames": "2.5.1",
    "codemirror": "6.0.2",
    "framer-motion": "12.42.2",
    "graphql": "16.11.0",
    "html-to-image": "1.11.13",
    "lodash": "4.18.1",
    "posthog-js": "1.399.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "10.1.0",
    "react-redux": "9.3.0",
    "react-router-dom": "7.18.1",
    "reactflow": "11.11.4",
    "redux-persist": "6.0.0",
    "remark-gfm": "4.0.1",
    "rxjs": "7.8.2",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.2",
    "uuid": "14.0.1"
  },
  "scripts": {
    "start": "vite --port 3000 --open",
    "build": "tsc -p tsconfig.ce.json && vite build",
    "build:ce": "tsc -p tsconfig.ce.json && vite build",
    "# E2E test commands": "",
    "e2e:ce": "VITE_E2E_TEST=true bash ../dev/run-e2e.sh false all",
    "e2e:ce:headless": "VITE_E2E_TEST=true bash ../dev/run-e2e.sh true all",
    "e2e:ce:headless:debug": "DEBUG=pw:api VITE_E2E_TEST=true bash ../dev/run-e2e.sh true all",
    "# Feature-specific commands - usage: pnpm e2e:feature <feature> (e.g., pnpm e2e:feature graph)": "",
    "# Features: accessibility, chat, cloud-providers, crud, data-types, data-view, database-contracts, error-handling, explore, export, graph, health-overlays, import, key-types, keyboard-shortcuts, loading-states, login, mock-data, negative-paths, pagination, profiles, query-history, schema-management, scratchpad, search, settings, sidebar, sorting, ssl-config, ssl-modes, storage, tables-list, tour, type-casting, where-conditions": "",
    "e2e:feature": "VITE_E2E_TEST=true bash ../dev/run-e2e.sh false all",
    "e2e:feature:headless": "VITE_E2E_TEST=true bash ../dev/run-e2e.sh true all",
    "# Database-specific commands - usage: pnpm e2e:db [database]": "",
    "# Available databases: postgres, mysql, mysql8, mariadb, tidb, sqlite, duckdb, mongodb, redis, elasticsearch, cockroachdb, clickhouse, memcached, valkey, dragonfly, opensearch, yugabytedb, questdb, ferretdb": "",
    "e2e:db": "VITE_E2E_TEST=true bash ../dev/run-e2e.sh false",
    "e2e:db:headless": "VITE_E2E_TEST=true bash ../dev/run-e2e.sh true",
    "e2e:keyboard:postgres:headless": "VITE_E2E_TEST=true WHODB_PW_NO_DEPS=true bash ../dev/run-e2e.sh true postgres keyboard-shortcuts",
    "screenshot": "VITE_E2E_TEST=true bash ../dev/run-screenshot-tests.sh",
    "screenshot:copy": "bash ../dev/copy-screenshots.sh",
    "# Auxiliary test commands": "",
    "_test:ce:setup": "bash ../dev/setup-e2e.sh ce && NODE_ENV=test vite --port 3000 &",
    "_test:ce:cleanup": "pkill -f 'vite --port 3000' || true; bash ../dev/cleanup-e2e.sh ce",
    "# Coverage and code generation utilities": "",
    "view:coverage": "nyc report --reporter=text-summary",
    "view:coverage:frontend": "nyc report --reporter=html && open coverage/index.html",
    "coverage:merge": "nyc merge .nyc_output coverage/coverage-final.json",
    "coverage:clean": "rm -rf .nyc_output coverage",
    "coverage:clean:all": "bash ../dev/clean-coverage.sh",
    "view:coverage:backend": "cd ../core && go tool cover -html=coverage.out",
    "generate": "graphql-codegen --config codegen.yml",
    "lint": "oxlint --deny-warnings src/",
    "lint:fix": "oxlint --fix src/",
    "oxlint": "oxlint src/",
    "oxlint:fix": "oxlint --fix src/",
    "typecheck": "tsc -p tsconfig.ce.json --noEmit",
    "test:analytics": "node scripts/run-analytics-tests.mjs"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@graphql-codegen/cli": "7.2.0",
    "@graphql-codegen/typed-document-node": "7.1.0",
    "@graphql-codegen/typescript": "6.1.0",
    "@graphql-codegen/typescript-operations": "6.1.0",
    "@graphql-typed-document-node/core": "3.2.0",
    "@lhci/cli": "0.15.1",
    "@oxlint/migrate": "1.73.0",
    "@playwright/test": "1.61.1",
    "@types/js-yaml": "4.0.9",
    "@types/lodash": "4.17.24",
    "@vitejs/plugin-react": "6.0.3",
    "baseline-browser-mapping": "2.10.43",
    "js-yaml": "5.2.1",
    "nyc": "18.0.0",
    "oxlint": "1.73.0",
    "oxlint-tsgolint": "0.24.0",
    "typescript": "6.0.3",
    "vite": "8.1.4",
    "vite-plugin-istanbul": "9.0.1"
  },
  "packageManager": "pnpm@11.15.1"
}
